VITE_SUPABASE_URL=YOUR_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=YOUR_ADMIN_PASSWORD

# Sentry 錯誤監控（可選，不設定則不啟用）
VITE_SENTRY_DSN=

# Lemon Squeezy 支付整合
VITE_LEMONSQUEEZY_STORE_ID=YOUR_STORE_ID
VITE_LEMONSQUEEZY_CHECKOUT_MONTHLY=https://your-store.lemonsqueezy.com/checkout/buy/monthly-variant-uuid
VITE_LEMONSQUEEZY_CHECKOUT_YEARLY=https://your-store.lemonsqueezy.com/checkout/buy/yearly-variant-uuid

# ──────────────────────────────────────────────────────────
# 以下 Secrets 設定在 Supabase Dashboard > Edge Functions，不放在 .env
# ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key        ← supabase secrets set ANTHROPIC_API_KEY=...
# LEMONSQUEEZY_WEBHOOK_SECRET=your_secret     ← supabase secrets set LEMONSQUEEZY_WEBHOOK_SECRET=...
#
# ⚠️ 注意：不要在 .env 中放 VITE_SUPABASE_SERVICE_KEY
# VITE_ 開頭的變數會被打包進前端 JS，service_role key 可繞過 RLS
