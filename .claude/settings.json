{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git fetch --all 2>&1 && git pull --ff-only origin $(git branch --show-current) 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Pulling latest from remote"
          }
        ]
      }
    ]
  }
}
