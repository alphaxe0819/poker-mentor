{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-sync.sh",
            "timeout": 30,
            "statusMessage": "Pulling latest from remote (auto-stash if WIP)"
          },
          {
            "type": "command",
            "command": "bash scripts/session-start-reminder.sh",
            "timeout": 5,
            "statusMessage": "開工 SOP 提醒注入中"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(cat)",
      "Bash(kill %1)",
      "Bash(wait)",
      "Bash(tasklist)",
      "Bash(tasklist.exe)",
      "Bash(python3)",
      "Bash(python -c ':*)",
      "Bash(python3 -c ':*)",
      "Bash(powershell -Command ':*)",
      "Bash(pip install:*)",
      "Bash(where python:*)",
      "Bash(where python3:*)",
      "Bash(where pip:*)",
      "Bash(where pip3:*)",
      "Bash(winget upgrade *)",
      "Bash(claude --version)",
      "Bash(claude update:*)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(python -m http.server 8765 --directory docs)",
      "Bash(npx -y http-server docs -p 8888 --cors)",
      "Bash(python -m scripts.package_skill \"../whiteboard\")",
      "Bash(python3 -c \"from PIL import Image; print\\('Pillow OK'\\)\")",
      "Bash(python -c \"from PIL import Image; print\\('Pillow OK'\\)\")",
      "Bash(curl -sL \"https://raw.githubusercontent.com/bupticybee/TexasSolver/console/resources/text/commandline_sample_input.txt\")",
      "Bash(curl -sL \"https://api.github.com/repos/bupticybee/TexasSolver/releases/latest\")",
      "Bash(curl -s -I \"https://poker-goal.vercel.app/deck.html\")",
      "Bash(curl -s \"https://poker-goal.vercel.app/deck.html\")",
      "Bash(cp /tmp/deck_latest.html public/deck.html)",
      "Bash(unzip -o ~/Downloads/TexasSolver-v0.2.0-Windows.zip -d scripts/gto-pipeline/solver/)",
      "Bash(timeout 60 scripts/gto-pipeline/solver/TexasSolver-v0.2.0-Windows/console_solver.exe)",
      "Bash(scripts/gto-pipeline/solver/TexasSolver-v0.2.0-Windows/console_solver.exe --help)",
      "Bash(scripts/gto-pipeline/solver/TexasSolver-v0.2.0-Windows/console_solver.exe --input_file scripts/gto-pipeline/test_solver.txt)",
      "Bash(scripts/gto-pipeline/solver/TexasSolver-v0.2.0-Windows/console_solver.exe --input_file scripts/gto-pipeline/test_solver.txt --resource_dir scripts/gto-pipeline/solver/TexasSolver-v0.2.0-Windows/resources)",
      "Bash(bash scripts/gto-pipeline/batch-solve.sh phase1a)",
      "Bash(powershell.exe -ExecutionPolicy Bypass -File batch-run.ps1 -SkipExisting)",
      "Bash(powershell.exe -Command \"Get-Process console_solver -ErrorAction SilentlyContinue\")",
      "Bash(powershell.exe -Command \"Get-Process console_solver -ErrorAction SilentlyContinue | Stop-Process -Force\")",
      "Bash(powershell.exe -Command \"Get-Process console_solver -ErrorAction SilentlyContinue | Stop-Process -Force; Write-Host 'Stopped'\")",
      "Bash(powershell.exe -Command \"Get-Process console_solver -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Sleep 1; Get-Process console_solver -ErrorAction SilentlyContinue || Write-Host 'Solver stopped'\")",
      "Bash(powershell.exe -Command \"Stop-Process -Name console_solver -Force\")",
      "Bash(powershell.exe -Command \"Stop-Process -Name console_solver -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 2; if \\(-not \\(Get-Process -Name console_solver -ErrorAction SilentlyContinue\\)\\) { Write-Host 'Solver stopped' }\")",
      "Bash(powershell.exe -Command 'Get-Process console_solver -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.Id -Force }')",
      "Bash(powershell.exe -Command 'while \\($true\\) { $p = Get-Process console_solver -ErrorAction SilentlyContinue; if \\(-not $p\\) { Write-Host '\\\\''All stopped'\\\\''; break }; $p | Stop-Process -Force; Start-Sleep -Milliseconds 500 }')",
      "Bash(taskkill.exe /F /IM console_solver.exe)",
      "Read(//tmp/**)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "WebSearch",
      "WebFetch(domain:lucidpoker.com)",
      "WebFetch(domain:poker.academy)",
      "WebFetch(domain:www.craftywheel.com)",
      "WebFetch(domain:gtowizard.com)",
      "WebFetch(domain:www.gtowizard.com)",
      "WebFetch(domain:blog.gtowizard.com)",
      "WebFetch(domain:lp.gtowizard.com)",
      "WebFetch(domain:help.gtowizard.com)",
      "WebFetch(domain:www.getcoach.poker)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:poker-goal.vercel.app)",
      "WebFetch(domain:www.taiwanrounders.com)",
      "WebFetch(domain:yangbear.com)",
      "WebFetch(domain:zhuanlan.zhihu.com)",
      "WebFetch(domain:www.toolify.ai)",
      "WebFetch(domain:solvers.poker)",
      "WebFetch(domain:www.similarweb.com)",
      "WebFetch(domain:apps.apple.com)",
      "WebFetch(domain:play.google.com)",
      "WebFetch(domain:chrome-stats.com)",
      "WebFetch(domain:www.gipsyteam.com)",
      "WebFetch(domain:www.zoominfo.com)",
      "WebFetch(domain:top.gg)",
      "WebFetch(domain:www.pokersnowie.com)",
      "WebFetch(domain:www.semrush.com)",
      "WebFetch(domain:apptopia.com)",
      "WebFetch(domain:gutshotmagazine.com)",
      "WebFetch(domain:m.apkpure.com)",
      "WebFetch(domain:mwm.ai)",
      "WebFetch(domain:startup.sme.gov.tw)",
      "WebFetch(domain:www.wanchicpa.com.tw)",
      "WebFetch(domain:pokerdinosaur.com)",
      "mcp__Claude_Preview__preview_start",
      "mcp__Claude_in_Chrome__tabs_context_mcp",
      "mcp__Claude_in_Chrome__navigate",
      "mcp__Claude_in_Chrome__computer",
      "mcp__Claude_in_Chrome__javascript_tool",
      "mcp__Claude_in_Chrome__read_network_requests",
      "mcp__Claude_in_Chrome__read_page",
      "mcp__Claude_in_Chrome__find",
      "mcp__Claude_in_Chrome__read_console_messages",
      "mcp__Claude_in_Chrome__resize_window"
    ],
    "defaultMode": "bypassPermissions"
  }
}
